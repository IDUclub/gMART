FROM node:22-alpine AS test-ui-builder

WORKDIR /ui

COPY tools/test-ui/package*.json ./
RUN npm ci

COPY tools/test-ui/index.html tools/test-ui/vite.config.js ./
COPY tools/test-ui/src ./src
RUN npm run build


FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

COPY pyproject.toml uv.lock ./
RUN uv sync --locked --no-dev

COPY src/__init__.py src/__version__.py ./src/
COPY src/agents ./src/agents
COPY --from=test-ui-builder /ui/dist ./tools/test-ui/dist

ENV FASTAPI_WORKERS=4
ENV PORT=80

ENV PATH="/app/.venv/bin:$PATH"

EXPOSE 80

CMD ["sh", "-c", "uvicorn src.agents.main:app --host 0.0.0.0 --port ${PORT} --workers ${FASTAPI_WORKERS:-4}"]
